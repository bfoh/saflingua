-- ENABLRE REALTIME
-- This tells Supabase to broadcast changes to these tables.
DO $$ 
BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_publication WHERE pubname = 'supabase_realtime') THEN
    CREATE PUBLICATION supabase_realtime;
  END IF;
EXCEPTION WHEN OTHERS THEN
  -- Handle case where it already exists or other errors
  NULL;
END $$;

-- Try to add tables to publication. 
-- We use separate statements and ignore errors if they are already in the publication.
ALTER PUBLICATION supabase_realtime ADD TABLE messages;
ALTER PUBLICATION supabase_realtime ADD TABLE submissions;
ALTER PUBLICATION supabase_realtime ADD TABLE profiles;

-- EXTENSIONS
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

